{
	"name": "damp-block-c720",
	"type": "module",
	"scripts": {
		"dev": "export $(cat .dev.vars | xargs) && wrangler dev",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply mathiks-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply mathiks-db --remote",
		"db:pg:generate": "drizzle-kit generate --config drizzle-pg.config.ts",
		"db:pg:migrate": "drizzle-kit migrate --config drizzle-pg.config.ts"
	},
	"dependencies": {
		"@msgpack/msgpack": "^3.1.3",
		"@neondatabase/serverless": "^1.0.2",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.11.9"
	},
	"devDependencies": {
		"@types/node": "^25.2.3",
		"drizzle-kit": "^0.31.0",
		"wrangler": "^4.66.0"
	}
}